{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=sportsvenue;User=root;Password=12346789;charset=utf8mb4;Allow User Variables=True;"
  },
  "Jwt": {
    "SecretKey": "CHANGE-THIS-IN-PRODUCTION-MIN-32-CHARS!!",
